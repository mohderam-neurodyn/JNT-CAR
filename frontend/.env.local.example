# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google Maps API Key (required for map features)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Mapbox Access Token (alternative to Google Maps)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your-mapbox-access-token-here

# Razorpay Payment Gateway
NEXT_PUBLIC_RAZORPAY_KEY_ID=your-razorpay-key-id-here
